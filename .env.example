CLIENT_URL=http://127.0.0.1:5173
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
PORT=4000
# Untuk development lokal dengan SQLite:
# DATABASE_URL="file:./data/bimbel-absensi.db"
#
# Untuk production, gunakan PostgreSQL (contoh dengan Supabase/Neon/Railway):
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=8h
COOKIE_NAME=bimbel_access_token
COOKIE_SECURE=false
# PENTING: Ubah ke true saat deploy production dengan HTTPS untuk keamanan cookie
COOKIE_SAME_SITE=lax
ALLOW_BOOTSTRAP=false
BOOTSTRAP_KEY=
ADMIN_EMAIL=admin@bimbel.local
ADMIN_PASSWORD=ChangeMe123!
APP_URL=http://127.0.0.1:5173
VITE_API_URL=/api
VITE_API_PROXY_TARGET=http://127.0.0.1:4000
EXPO_PUBLIC_API_URL=http://localhost:4000/api
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
WHATSAPP_SENDER=Bimbel
QR_SECRET=change-this-to-another-random-secret
QR_EXPIRES_MINUTES=120
