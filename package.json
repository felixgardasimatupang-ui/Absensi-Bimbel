{
  "name": "bimbel-absensi-platform",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:all": "concurrently \"npm run dev:server\" \"npm run dev:client\" \"npm run dev:mobile\"",
    "dev:client": "npm run dev --workspace client",
    "dev:server": "npm run dev --workspace server",
    "dev:mobile": "cd mobile-app && npm start",
    "setup": "npm install && npm run prisma:setup",
    "prisma:setup": "cd server && npx prisma generate && npx prisma db push && node prisma/seed.js",
    "prisma:generate": "npm run prisma:generate --workspace server",
    "prisma:migrate": "npm run prisma:migrate --workspace server",
    "prisma:seed": "npm run prisma:seed --workspace server",
    "build": "npm run build --workspace client"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "postgres": "^3.4.8"
  }
}